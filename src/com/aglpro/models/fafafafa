package com.aglpro.models;

public class Administrateur extends Utilisateur {

    // Constructeur vide
    public Administrateur() {}

    // Constructeur complet
    public Administrateur(int id, String nom, 
                          String email, String motDePasse) {
        super(id, nom, email, motDePasse);
    }

    // Méthodes métier
    public void gererUtilisateur(Utilisateur utilisateur) {
        System.out.println("Gestion utilisateur: " + 
                           utilisateur.getNom());
    }

    public void consulterStatistiques() {
        System.out.println("Consultation des statistiques...");
    }
}
